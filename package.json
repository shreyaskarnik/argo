{
  "name": "@argo-video/cli",
  "version": "0.12.1",
  "description": "Turn Playwright demo scripts into polished product demo videos with AI voiceover",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "argo": "./bin/argo.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0",
    "playwright": ">=1.40.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0-next.7",
    "commander": "^12.0.0",
    "kokoro-js": "^1.2.1"
  },
  "optionalDependencies": {
    "@elevenlabs/elevenlabs-js": "^2.0.0",
    "@google/genai": "^1.0.0",
    "openai": "^4.0.0",
    "sarvamai": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shreyaskarnik/argo.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "scripts"
  ],
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.5.0",
    "playwright": "^1.50.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
